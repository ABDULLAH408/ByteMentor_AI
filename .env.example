# ========================================================
# ByteMentor AI - Production Environment Variables Template
# ========================================================

# --------------------------------------------------------
# Backend Environment Variables (AWS Lambda Stack Configurations)
# --------------------------------------------------------

# The region where DynamoDB and SES are deployed (e.g. us-east-1, us-west-2)
AWS_REGION=us-east-1

# DynamoDB Table Name for storing profiles and daily lessons
TABLE_NAME=ByteMentorLessons

# AWS Bedrock model to invoke for lesson generation
# Recommended: us.amazon.nova-lite-v1:0 (Nova Lite)
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0

# The region where AWS Bedrock model is hosted and enabled (e.g. us-east-1, us-west-2)
BEDROCK_REGION=us-east-1

# (Optional) Sender email verified in AWS SES to send daily email lessons
# Leave empty to disable daily email dispatches
SES_EMAIL_SENDER=sender@example.com

# (Optional) Recipient email address to receive the daily email lessons
# Leave empty to disable daily email dispatches
SES_EMAIL_RECIPIENT=recipient@example.com


# --------------------------------------------------------
# Frontend Environment Variables (AWS Amplify Console / Static Site)
# --------------------------------------------------------

# The Lambda Public Function URL or API Gateway URL pointing to the backend
# Example: https://xxxxxxxxxxxxxx.lambda-url.us-east-1.on.aws/
VITE_API_URL=https://your-lambda-function-url.lambda-url.us-east-1.on.aws
